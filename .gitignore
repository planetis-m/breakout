# Ignore all root files
/*
# Exclude readme file
!/*.md
!/*.rst
!/*.nim
!/*.h
# Exclude root directories
!/*/
!/.github/
# Include all files in subdirectories
/*/*
# Exclude source code files in subdirectories
!/*/*.nim
!/*/*.txt
!/.github/*
# Exclude root subdirectories
!/*/*/
# Include all files in sub-subdirectories
/*/*/*
# Exclude source code files in sub-subdirectories
!/*/*/*.nim
!/*/*/*.txt
!/.github/*/*.yml
